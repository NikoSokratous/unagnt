# Kubernetes operator image. Uses committed generated code (run make generate-crds before building).
FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /unagnt-operator ./k8s/operator/cmd

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /unagnt-operator /usr/local/bin/
ENTRYPOINT ["/usr/local/bin/unagnt-operator"]
